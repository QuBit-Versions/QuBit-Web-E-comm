# Copie para .env.local e preencha. Nada aqui é obrigatório para rodar em dev.

# WhatsApp (apenas dígitos, com DDI+DDD). Ex.: 5521999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics — sem isso, os scripts simplesmente não carregam
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Destino do formulário de diagnóstico (webhook que recebe POST JSON).
# Sem isso, em dev o lead é apenas logado no console do servidor.
FORM_SUBMISSION_WEBHOOK=
