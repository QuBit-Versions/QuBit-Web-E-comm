# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (segredos locais) — mas mantém o exemplo versionado
.env*
!.env.example

# config local de MCP (caminhos da máquina, não faz parte do site)
.mcp.json

# backups de assets
*.glb.bak
*.v4bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local overrides (contém credenciais — nunca commitar)
.claude/settings.local.json
