# Copie para .env.local e preencha. Nada aqui é obrigatório para rodar em dev.

# WhatsApp (apenas dígitos, com DDI+DDD). Ex.: 5521999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics — sem isso, os scripts simplesmente não carregam
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Supabase — destino dos leads do diagnóstico (tabela public.diagnosticos).
# A publishable key é pública (segura no cliente); o RLS protege os dados.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Webhook opcional do formulário (POST JSON) — ex.: notificação Slack/WhatsApp.
# Sem Supabase nem webhook, em dev o lead é apenas logado no console.
FORM_SUBMISSION_WEBHOOK=
